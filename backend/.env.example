# SERVER
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# DATABASE (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Note: DATABASE_URL uses pgbouncer for connection pooling.
# DIRECT_URL is used by Prisma migrations and bypasses pgbouncer.

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AUTH
JWT_SECRET=minimum-32-character-random-secret-key-here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
ADMIN_REGISTRATION_SECRET=secret-key-to-register-admin-accounts

# REDIS (Upstash)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# AI (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FAST_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_VISION_MODEL=google/gemini-flash-1.5
OPENROUTER_ONLINE_MODEL=anthropic/claude-3.5-sonnet:online

# FIRECRAWL (AI Research)
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# AI RESEARCH CONFIG
AI_RESEARCH_CACHE_HOURS=24
AI_RESEARCH_RATE_LIMIT=10
AI_RESEARCH_RATE_WINDOW_MS=3600000

# EMAIL (Resend)
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=noreply@devupecosystem.in
RESEND_FROM_NAME=DevUp Ecosystem
RESEND_TEAM_EMAIL=team@devupecosystem.in
RESEND_ADMIN_EMAIL=admin@devupecosystem.in

# FILE STORAGE (Supabase Storage)
STORAGE_BUCKET_LOGOS=startup-logos
STORAGE_BUCKET_BANNERS=startup-banners
STORAGE_BUCKET_DOCUMENTS=legal-documents
STORAGE_BUCKET_RESUMES=candidate-resumes
STORAGE_BUCKET_PITCHDECKS=pitch-decks
MAX_FILE_SIZE_MB=10

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=3600000

# LOGGING
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# MONITORING (optional)
SENTRY_DSN=optional-sentry-dsn-for-error-tracking

# PRODUCTION VALUES
# NODE_ENV=production
# PORT=4000
# FRONTEND_URL=https://devupecosystem.in
# ADMIN_URL=https://admin.devupecosystem.in
# CORS_ORIGINS=https://devupecosystem.in,https://admin.devupecosystem.in
